{
  "compileOnSave": true,
  "compilerOptions": {
    "moduleResolution": "bundler",
    "ignoreDeprecations": "5.0",
    "target": "ES6",
    "module": "ES6",
    "allowJs": true,
    "sourceMap": true,
    "declaration": true,
    "lib": ["es2016", "dom"],
    "noImplicitAny": false,
    "strictNullChecks": false,
    "noEmitOnError": false
  },
  "include": ["*.ts", "./**/*.ts"],
  "exclude": ["node_modules", "**/seedrandom*"]
}
